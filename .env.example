# Supabase — get these from https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# App URL (used for auth redirects and OpenRouter HTTP-Referer)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI Provider — Sprint 5b / 5b.1
# Recommended for CN dev: OpenRouter (OpenAI-compatible API)
ENABLE_LLM=false
LLM_PROVIDER=openrouter
LLM_API_KEY=
LLM_MODEL=openai/gpt-4o-mini
LLM_BASE_URL=https://openrouter.ai/api/v1

# Legacy OpenAI env vars (still supported as fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Notes:
# - Priority: LLM_API_KEY > OPENAI_API_KEY; LLM_MODEL > OPENAI_MODEL
# - OpenRouter: set LLM_PROVIDER=openrouter + LLM_API_KEY from https://openrouter.ai/keys
# - OpenAI official API: omit LLM_PROVIDER or set LLM_BASE_URL=https://api.openai.com/v1
